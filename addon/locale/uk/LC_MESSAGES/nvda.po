#. Translators: label of a dialog presented when installing this addon and placeMarkersBackup is found.
#: addon/installTasks.py:32
msgid ""
"Your configuration folder for NVDA contains files that seem to be derived "
"from a previous version of this add-on. Do you want to update it?"
msgstr ""
"Ваша тека конфігурації NVDA містить файли, які, схоже, походять від "
"попередньої версії цього додатка. Ви хочете її оновити?"

#. Translators: title of a dialog presented when installing this addon and placeMarkersBackup is found.
#: addon/installTasks.py:36
msgid "Install or update add-on"
msgstr "Встановити чи оновити додаток"

#. Translators: message presented when a string of text has been copied to the clipboard.
#: addon/globalPlugins/placeMarkers/__init__.py:251
#, python-format
msgid "%s copied to clipboard"
msgstr "%s скопійовано в буфер обміну"

#. Translators: The title of the Specific Search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:390
msgid "Specific search"
msgstr "Конкретний пошук"

#. Translators: The label of a combo box in the Specific Search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:397
msgid "Sa&ved texts"
msgstr "З&бережені тексти"

#. Translators: A label for a chekbox in the Specific search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:405
msgid "&Remove from history"
msgstr "&Видалити з історії"

#. Translators: The label of an edit box in the Specific Search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:408
msgid "&Text to search:"
msgstr "&Текст для пошуку:"

#. Translators: A label for a chekbox in the Specific search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:413
msgid "&Add to history"
msgstr "&Додати до історії"

#. Translators: Label for a set of radio buttons in the Specific search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:415
msgid "Action on s&earch"
msgstr "Дія під час п&ошуку"

#. Translators: An action in the Search group of the Specific search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:418
msgid "Search &next"
msgstr "Шукати &далі"

#. Translators: An action in the Search group of the Specific search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:420
msgid "Search &previous"
msgstr "Шукати &попереднє"

#. Translators: An action in the Search group of the Specific search dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:422
msgid "&Don't search"
msgstr "&Не шукати"

#. Translators: Message presented when place markers have been copied.
#: addon/globalPlugins/placeMarkers/__init__.py:510
msgid "Place markers copied"
msgstr "Маркери місць скопійовано"

#. Translators: label of error dialog shown when cannot copy placeMarkers folder.
#: addon/globalPlugins/placeMarkers/__init__.py:516
#: addon/globalPlugins/placeMarkers/__init__.py:537
msgid "Folder not copied"
msgstr "Теку не скопійовано"

#. Translators: title of error dialog shown when cannot copy placeMarkers folder.
#: addon/globalPlugins/placeMarkers/__init__.py:518
#: addon/globalPlugins/placeMarkers/__init__.py:539
msgid "Copy Error"
msgstr "Помилка копіювання"

#. Translators: Message presented when place markers have been restored.
#: addon/globalPlugins/placeMarkers/__init__.py:531
msgid "Place markers restored"
msgstr "Маркери місць відновлено"

#. Translators: The title of the Notes dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:549
msgid "Notes"
msgstr "Примітки"

#. Translators: The label of a list box in the Notes dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:554
msgid "&Bookmarks"
msgstr "&Закладки"

#. Translators: The label of an edit box in the Notes dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:566
msgid "Not&e:"
msgstr "&Примітка:"

#. Translators: The label for a button in the Notes dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:578
msgid "&Save note"
msgstr "&Зберегти примітку"

#. Translators: The label for a button in the Notes dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:581
msgid "&Delete..."
msgstr "&Видалити..."

#. Translators: The confirmation prompt displayed when the user requests to delete a bookmark.
#: addon/globalPlugins/placeMarkers/__init__.py:612
msgid ""
"This bookmark will be permanently deleted. This action cannot be undone."
msgstr "Цю закладку буде видалено безповоротно. Цю дію неможливо скасувати."

#. Translators: The message presented when all bookmarks have been deleted from the Notes dialog.
#. Translators: message presented when the current document doesn't contain bookmarks.
#: addon/globalPlugins/placeMarkers/__init__.py:639
#: addon/globalPlugins/placeMarkers/__init__.py:1091
#: addon/globalPlugins/placeMarkers/__init__.py:1187
#: addon/globalPlugins/placeMarkers/__init__.py:1222
msgid "No bookmarks"
msgstr "Немає закладок"

#. Translators: The title of the warning dialog when all bookmarks have been deleted.
#: addon/globalPlugins/placeMarkers/__init__.py:641
msgid "Bookmarks deleted"
msgstr "Закладки видалено"

#. Translators: The title of the Copy dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:655
msgid "Copy place markers"
msgstr "Копіювання маркерів місць"

#. Translators: An informational message displayed in the Copy dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:661
msgid "Select a folder to save a backup of your current place markers."
msgstr ""
"Виберіть теку для збереження резервної копії ваших поточних маркерів місць."

#. Translators: The label of a grouping with controls to select the destination directory in the Copy dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:665
msgid "directory for backup:"
msgstr "тека для резервних копій:"

#. Translators: The title of the dialog to browse for the destination directory when copying place markers.
#: addon/globalPlugins/placeMarkers/__init__.py:675
msgid "Select directory to copy"
msgstr "Виберіть каталог для копіювання"

#. Translators: The title of the Set default folder dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:721
msgid "Set default folder for place markers"
msgstr "Встановити теку за замовчуванням для маркерів місць"

#. Translators: An informational message displayed in the Set default folder dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:727
msgid "Select the folder where your place markers will be searched."
msgstr "Виберіть теку, де здійснюватиметься пошук ваших маркерів місць."

#. Translators: The label of a grouping with controls to select the folder in the Set default folder dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:731
msgid "default directory for place markers:"
msgstr "типовий каталог для маркерів місць:"

#. Translators: The title of the dialog to browse for the default directory for place markers.
#: addon/globalPlugins/placeMarkers/__init__.py:741
msgid "Select default directory"
msgstr "Виберіть каталог за замовчуванням"

#. Translators: The title of the Restore dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:808
msgid "Restore place markers"
msgstr "Відновити маркери місць"

#. Translators: An informational message displayed in the Restore dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:814
msgid ""
"Select a folder to restore a backup of your previous copied place markers."
msgstr ""
"Виберіть теку для відновлення резервної копії раніше скопійованих маркерів "
"місць."

#. Translators: The label of a grouping with controls to select the destination directory in Restore dialog.
#: addon/globalPlugins/placeMarkers/__init__.py:818
msgid "directory containing backup:"
msgstr "каталог з резервними копіями:"

#. Translators: The title of the dialog to browse for the destination directory when restoring place markers.
#: addon/globalPlugins/placeMarkers/__init__.py:828
msgid "Select directory to restore"
msgstr "Виберіть каталог для відновлення"

#. Translators: the name of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:896
msgid "P&lace markers"
msgstr "&Маркери місць"

#. Translators: the tooltip text for addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:898
msgid "Bookmarks and Search menu"
msgstr "Меню закладок і пошуку"

#. Translators: the name for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:903
msgid "&Specific search folder"
msgstr "&Тека конкретного пошуку"

#. Translators: the tooltip text for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:905
msgid "Opens the specific search folder"
msgstr "Відкриває теку конкретного пошуку"

#. Translators: the name for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:911
msgid "&Bookmarks folder"
msgstr "&Тека закладок"

#. Translators: the tooltip text for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:913
msgid "Opens the bookmarks folder"
msgstr "Відкриває теку закладок"

#. Translators: the name for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:919
msgid "&Copy placeMarkers folder..."
msgstr "&Скопіювати теку placeMarkers..."

#. Translators: the tooltip text for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:921
msgid "Backup of place markers"
msgstr "Резервне копіювання маркерів місць"

#. Translators: the name for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:927
msgid "R&estore place markers..."
msgstr "Відновити м&аркери місць..."

#. Translators: the tooltip text for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:929
msgid "Restore previously saved place markers"
msgstr "Відновити попередньо збережені маркери місць"

#. Translators: the name for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:935
msgid "Set &default place markers folder..."
msgstr "Установити &теку маркерів місць за замовчуванням..."

#. Translators: the tooltip text for an item of addon submenu.
#: addon/globalPlugins/placeMarkers/__init__.py:937
msgid "Sets default folder for place markers"
msgstr "Встановлює теку за замовчуванням для маркерів місць"

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:959
msgid "Opens the specific search folder."
msgstr "Відкриває теку конкретного пошуку."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:969
msgid "Opens the bookmarks folder."
msgstr "Відкриває теку закладок."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:982
#, python-format
msgid "Activates the Copy dialog of %s."
msgstr "Активовує діалог копіювання з %s."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:995
#, python-format
msgid "Activates the Restore dialog of %s."
msgstr "Активує діалог відновлення з %s."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1008
#, python-format
msgid "Activates the Set default folder dialog of %s."
msgstr "Відкриває діалог вибору каталогу за замовчуванням для %s."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1015
msgid ""
"finds a text string from the current cursor position for a specific document."
msgstr "шукає рядок тексту з поточної позиції курсора для певного документа."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1041
msgid ""
"finds the next occurrence of the last text searched for any specific "
"document."
msgstr ""
"знаходить наступний фрагмент останнього шуканого тексту в будь-якому "
"конкретному документі."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1065
msgid ""
"finds the previous occurrence of the last text searched for any specific "
"document."
msgstr ""
"знаходить попередній фрагмент останнього шуканого тексту в будь-якому "
"конкретному документі."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1101
msgid "Show the Notes dialog for a specific document."
msgstr "Показати діалог приміток для певного документа."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1120
msgid "Saves the current position as a bookmark."
msgstr "Зберігає поточну позицію як закладку."

#. Translators: message presented when a position is saved as a bookmark.
#: addon/globalPlugins/placeMarkers/__init__.py:1160
#, python-format
msgid "Saved position at character %d"
msgstr "Позицію збережено на символі %d"

#. Translators: message presented when a bookmark cannot be saved.
#: addon/globalPlugins/placeMarkers/__init__.py:1166
msgid "Cannot save bookmark"
msgstr "Неможливо зберегти закладку"

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1172
msgid "Deletes the current bookmark."
msgstr "Видаляє поточну закладку."

#. Translators: message presented when the current document has bookmarks, but none is selected.
#: addon/globalPlugins/placeMarkers/__init__.py:1201
msgid "No bookmark selected"
msgstr "Немає виділених закладок"

#. Translators: message presented when a bookmark is deleted.
#: addon/globalPlugins/placeMarkers/__init__.py:1212
msgid "Bookmark deleted"
msgstr "Закладку видалено"

#. Translators: message presented when cannot delete a bookmark.
#: addon/globalPlugins/placeMarkers/__init__.py:1230
msgid "Cannot delete bookmark"
msgstr "Неможливо видалити закладку"

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1235
msgid "Moves to the next bookmark."
msgstr "Переходить до наступної закладки."

#. Translators: message presented when trying to select a bookmark, but none is found.
#: addon/globalPlugins/placeMarkers/__init__.py:1255
#: addon/globalPlugins/placeMarkers/__init__.py:1308
msgid "No bookmarks found"
msgstr "Немає знайдених закладок"

#. Translators: message presented when a bookmark is selected.
#: addon/globalPlugins/placeMarkers/__init__.py:1278
#: addon/globalPlugins/placeMarkers/__init__.py:1331
#, python-format
msgid "Position: character %d"
msgstr "Позиція: символ %d"

#. Translators: message presented when the next bookmark is not found.
#: addon/globalPlugins/placeMarkers/__init__.py:1283
msgid "Next bookmark not found"
msgstr "Наступну закладку не знайдено."

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1288
msgid "Moves to the previous bookmark."
msgstr "Переходить до попередньої закладки."

#. Translators: message presented when the previous bookmark is not found.
#: addon/globalPlugins/placeMarkers/__init__.py:1336
msgid "Previous bookmark not found"
msgstr "Попередню закладку не знайдено"

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1341
msgid "Shows the name of the current file for place markers in browse mode."
msgstr "Показує ім’я поточного файлу для маркерів місць у режимі огляду."

#. Translators: Presented when the current document has positional bookmarks.
#: addon/globalPlugins/placeMarkers/__init__.py:1356
msgid "Has bookmarks."
msgstr "Містить закладку."

#. Translators: Presented when the current document has specific search.
#: addon/globalPlugins/placeMarkers/__init__.py:1359
msgid "Has text for specific search."
msgstr "Містить текст для конкретного пошуку."

#. Translators: Presented when the current document has a temporary bookmark.
#: addon/globalPlugins/placeMarkers/__init__.py:1362
msgid "Has temporary bookmark."
msgstr "Містить тимчасову закладку."

#. Translators: Title for a message presented when the file name for place markers is shown in browse mode.
#: addon/globalPlugins/placeMarkers/__init__.py:1366
#, python-format
msgid "%s file"
msgstr "%s файл"

#. Translators: message presented in input mode, when a keystroke of an addon script is pressed.
#: addon/globalPlugins/placeMarkers/__init__.py:1373
msgid "Saves the current position as a temporary bookmark."
msgstr "Зберігає поточну позицію як тимчасову закладку."

#. Translators: Message presented when a temporary bookmark is saved.
#: addon/globalPlugins/placeMarkers/__init__.py:1400
#, python-format
msgid "Saved temporary bookmark at position %d"
msgstr "Тимчасову закладку збережено в позиції %d"

#. Translators: Message presented in input help mode.
#: addon/globalPlugins/placeMarkers/__init__.py:1407
msgid "Moves to the temporary bookmark for the current document."
msgstr "Переходить до тимчасової закладки в поточному документі."

#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on to be shown on installation and add-on information.
#: buildVars.py:17
msgid "Place markers"
msgstr "Маркери місць"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:20
msgid "Add-on for setting place markers on specific virtual documents"
msgstr "Додаток для маркування місць у певних віртуальних документах"
