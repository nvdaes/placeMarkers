#. Translators: the name for an item of addon submenu.
#: addon\globalPlugins\placeMarkers\__init__.py:911
msgid "&Bookmarks folder"
msgstr "Cartafol &Marcas"

#. Translators: the tooltip text for an item of addon submenu.
#: addon\globalPlugins\placeMarkers\__init__.py:913
msgid "Opens the bookmarks folder"
msgstr "Abre o cartafol marcas"

#. Translators: the name for an item of addon submenu.
#: addon\globalPlugins\placeMarkers\__init__.py:919
msgid "&Copy placeMarkers folder..."
msgstr "&Copiar cartafol marcas..."

#. Translators: the tooltip text for an item of addon submenu.
#: addon\globalPlugins\placeMarkers\__init__.py:921
